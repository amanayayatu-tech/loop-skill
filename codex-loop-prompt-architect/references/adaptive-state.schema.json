    "finalizationOutbox": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finalization_id",
        "status",
        "finalized_state_version",
        "controller_goal_id",
        "automation_id",
        "outcome_kind",
        "controller_goal_target_status",
        "automation_target_status",
        "blocker_code",
        "blocker_fingerprint",
        "blocker_observations",
        "blocker_report_path",
        "blocker_report_digest"
      ],
      "properties": {
        "finalization_id": {"$ref": "#/$defs/safeId"},
        "status": {"enum": ["PREPARED", "ACKED"]},
        "finalized_state_version": {"type": "integer", "minimum": 1},
        "controller_goal_id": {"$ref": "#/$defs/safeId"},
        "automation_id": {"$ref": "#/$defs/safeId"},
        "outcome_kind": {"enum": ["SUCCESS", "BLOCKED"]},
        "controller_goal_target_status": {"enum": ["COMPLETE", "BLOCKED"]},
        "automation_target_status": {"const": "PAUSED"},
        "blocker_code": {
          "oneOf": [{"type": "null"}, {"$ref": "#/$defs/safeId"}]
        },
        "blocker_fingerprint": {
          "oneOf": [{"type": "null"}, {"$ref": "#/$defs/digest"}]
        },
        "blocker_observations": {
          "type": "array",
          "maxItems": 3,
          "items": {"$ref": "#/$defs/blockerObservation"}
        },
        "blocker_report_path": {
          "oneOf": [{"type": "null"}, {"type": "string", "minLength": 1}]
        },
        "blocker_report_digest": {
          "oneOf": [{"type": "null"}, {"$ref": "#/$defs/digest"}]
        }
      },
      "allOf": [
        {
          "if": {"properties": {"outcome_kind": {"const": "SUCCESS"}}},
          "then": {
            "properties": {
              "controller_goal_target_status": {"const": "COMPLETE"},
              "blocker_code": {"type": "null"},
              "blocker_fingerprint": {"type": "null"},
              "blocker_observations": {"maxItems": 0},
              "blocker_report_path": {"type": "null"},
              "blocker_report_digest": {"type": "null"}
            }
          }
        },
        {
          "if": {"properties": {"outcome_kind": {"const": "BLOCKED"}}},
          "then": {
            "properties": {
              "controller_goal_target_status": {"const": "BLOCKED"},
              "blocker_code": {"$ref": "#/$defs/safeId"},
              "blocker_fingerprint": {"$ref": "#/$defs/digest"},
              "blocker_observations": {"minItems": 3, "maxItems": 3},
              "blocker_report_path": {"type": "string", "minLength": 1},
              "blocker_report_digest": {"$ref": "#/$defs/digest"}
            }
          }
        }
      ]
    },
    "finalizationReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finalization_id",
        "controller_goal_id",
      "controller_goal_status",
      "controller_goal_observation_path",
      "controller_goal_observation_digest",
      "automation_id",
      "automation_status",
      "automation_observation_path",
      "automation_observation_digest",
      "outcome_kind",
      "blocker_code",
      "blocker_fingerprint",
      "blocker_observations",
      "blocker_report_path",
      "blocker_report_digest",
      "ack_state_version",
        "evidence_paths"
      ],
      "properties": {
        "finalization_id": {"$ref": "#/$defs/safeId"},
        "controller_goal_id": {"$ref": "#/$defs/safeId"},
        "controller_goal_status": {"enum": ["COMPLETE", "BLOCKED"]},
