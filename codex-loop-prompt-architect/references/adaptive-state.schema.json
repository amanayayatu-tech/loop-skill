        "automation_status": {"const": "PAUSED"},
        "automation_observation_path": {"type": "string", "minLength": 1},
        "automation_observation_digest": {"$ref": "#/$defs/digest"},
        "outcome_kind": {"enum": ["SUCCESS", "BLOCKED"]},
        "blocker_code": {
          "oneOf": [{"type": "null"}, {"$ref": "#/$defs/safeId"}]
        },
        "blocker_fingerprint": {
          "oneOf": [{"type": "null"}, {"$ref": "#/$defs/digest"}]
        },
        "blocker_observations": {
          "type": "array",
          "maxItems": 3,
          "items": {"$ref": "#/$defs/blockerObservation"}
        },
        "blocker_report_path": {
          "oneOf": [{"type": "null"}, {"type": "string", "minLength": 1}]
        },
        "blocker_report_digest": {
          "oneOf": [{"type": "null"}, {"$ref": "#/$defs/digest"}]
        },
        "ack_state_version": {"type": "integer", "minimum": 1},
        "evidence_paths": {"$ref": "#/$defs/stringArray"}
      },
      "allOf": [
        {
          "if": {"properties": {"outcome_kind": {"const": "SUCCESS"}}},
          "then": {
            "properties": {
              "controller_goal_status": {"const": "COMPLETE"},
              "blocker_code": {"type": "null"},
              "blocker_fingerprint": {"type": "null"},
              "blocker_observations": {"maxItems": 0},
              "blocker_report_path": {"type": "null"},
              "blocker_report_digest": {"type": "null"}
            }
          }
        },
        {
          "if": {"properties": {"outcome_kind": {"const": "BLOCKED"}}},
          "then": {
            "properties": {
              "controller_goal_status": {"const": "BLOCKED"},
              "blocker_code": {"$ref": "#/$defs/safeId"},
              "blocker_fingerprint": {"$ref": "#/$defs/digest"},
              "blocker_observations": {"minItems": 3, "maxItems": 3},
              "blocker_report_path": {"type": "string", "minLength": 1},
              "blocker_report_digest": {"$ref": "#/$defs/digest"}
            }
          }
        }
      ]
    },
